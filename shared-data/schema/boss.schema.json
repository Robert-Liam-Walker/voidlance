{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "boss.schema.json",
  "title": "Boss",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "coreHp", "size", "entryY", "swayAmp", "swayMs", "bulletSpeed", "fireRateMs", "scoreValue", "coinValue", "tint", "parts"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "coreAttack": { "enum": ["spread", "radialBurst", "spiral"], "description": "Core firing style. Omitted = 'spread' (player-aimed fan). 'radialBurst' = aimed fan with periodic full-circle volleys at low HP. 'spiral' = continuous rotating arms." },
    "coreHp": { "type": "integer", "minimum": 1 },
    "size": { "type": "number", "minimum": 8 },
    "entryY": { "type": "number", "minimum": 0 },
    "swayAmp": { "type": "number", "minimum": 0 },
    "swayMs": { "type": "number", "minimum": 1 },
    "bulletSpeed": { "type": "number", "minimum": 0 },
    "fireRateMs": { "type": "number", "minimum": 1 },
    "scoreValue": { "type": "integer", "minimum": 0 },
    "coinValue": { "type": "integer", "minimum": 0 },
    "tint": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
    "parts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "offsetX", "offsetY", "hp", "size", "fireRateMs", "pattern", "tint"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "offsetX": { "type": "number" },
          "offsetY": { "type": "number" },
          "hp": { "type": "integer", "minimum": 1 },
          "size": { "type": "number", "minimum": 8 },
          "fireRateMs": { "type": "number", "minimum": 1 },
          "pattern": { "enum": ["aimed", "spread", "none"] },
          "tint": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" }
        }
      }
    }
  }
}

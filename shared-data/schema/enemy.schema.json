{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "enemy.schema.json",
  "title": "Enemy",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "hp", "behavior", "size", "scoreValue", "coinValue", "tint", "speed", "sprite", "bulletSprite"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "hp": { "type": "integer", "minimum": 1 },
    "behavior": { "enum": ["fighter", "smasher", "builder", "transport", "demolisher", "razer", "emitter", "phantom", "interceptor"] },
    "size": { "type": "number", "minimum": 8 },
    "scoreValue": { "type": "integer", "minimum": 0 },
    "coinValue": { "type": "integer", "minimum": 0 },
    "tint": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
    "speed": { "type": "number", "minimum": 0 },
    "sprite": { "type": "string", "minLength": 1 },
    "bulletSprite": { "type": "string", "minLength": 1 },
    "fireChance": { "type": "number", "minimum": 0, "maximum": 1 },
    "bulletSpeed": { "type": "number", "minimum": 0 }
  }
}

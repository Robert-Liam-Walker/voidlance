{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "theme.schema.json",
  "title": "Theme",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "tagline", "palette", "player", "background", "enemyRosterIds", "levelIds"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "tagline": { "type": "string" },
    "palette": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bg", "bgAccent", "accent", "text", "danger"],
      "properties": {
        "bg": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "bgAccent": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "accent": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "text": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "danger": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" }
      }
    },
    "player": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tint", "bulletTint", "shape", "fireRateMs", "bulletSpeed", "bulletDamage", "maxHp"],
      "properties": {
        "tint": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "bulletTint": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "shape": { "enum": ["arrow", "wasp"] },
        "fireRateMs": { "type": "integer", "minimum": 60 },
        "bulletSpeed": { "type": "number", "minimum": 100 },
        "bulletDamage": { "type": "integer", "minimum": 1 },
        "maxHp": { "type": "integer", "minimum": 1 }
      }
    },
    "background": {
      "type": "object",
      "additionalProperties": false,
      "required": ["style", "starTint"],
      "properties": {
        "style": { "enum": ["starfield", "grid"] },
        "starTint": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" }
      }
    },
    "enemyRosterIds": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "powerupIds": { "type": "array", "items": { "type": "string" } },
    "levelIds": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "music": { "type": "string" }
  }
}

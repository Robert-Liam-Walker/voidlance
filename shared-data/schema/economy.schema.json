{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "economy.schema.json",
  "title": "Economy",
  "type": "object",
  "additionalProperties": false,
  "required": ["upgrades"],
  "properties": {
    "upgrades": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "stat", "perLevel", "baseCost", "costGrowth", "maxLevel"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "stat": { "enum": ["bulletDamage", "fireRateMs", "maxHp"] },
          "perLevel": { "type": "number" },
          "baseCost": { "type": "integer", "minimum": 0 },
          "costGrowth": { "type": "number", "minimum": 1 },
          "maxLevel": { "type": "integer", "minimum": 1 }
        }
      }
    }
  }
}

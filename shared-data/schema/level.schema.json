{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "level.schema.json",
  "title": "Level",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "waves"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "waves": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "wave.schema.json" }
    }
  }
}

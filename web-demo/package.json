{
  "name": "voidlance-web-demo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "VOIDLANCE — Phase 0 web prototype (3D, Three.js + TypeScript). Real-3D render, 2D top-down gameplay. Loads the canonical shared-data/ schema.",
  "scripts": {
    "sync:data": "node scripts/sync-data.mjs",
    "validate:data": "node scripts/validate-data.mjs",
    "predev": "node scripts/sync-data.mjs",
    "dev": "vite",
    "prebuild": "node scripts/sync-data.mjs",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4173"
  },
  "dependencies": {
    "@types/three": "^0.184.1",
    "ajv": "^8.17.1",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "playwright-core": "^1.60.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.7"
  }
}

{
  "name": "voidlance-web-demo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "VOIDLANCE — Phase 0 web prototype (Phaser 3 + TypeScript). Loads the canonical shared-data/ schema.",
  "scripts": {
    "sync:data": "node scripts/sync-data.mjs",
    "validate:data": "node scripts/validate-data.mjs",
    "predev": "node scripts/sync-data.mjs",
    "dev": "vite",
    "prebuild": "node scripts/sync-data.mjs",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4173"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "phaser": "^3.86.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vite": "^6.0.7"
  }
}
